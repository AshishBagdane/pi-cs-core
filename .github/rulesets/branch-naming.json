{
  "name": "Branch naming convention",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["~ALL"],
      "exclude": ["refs/heads/main", "refs/heads/develop"]
    }
  },
  "rules": [
    {
      "type": "branch_name_pattern",
      "parameters": {
        "name": "Branch naming convention",
        "negate": false,
        "operator": "regex",
        "pattern": "^(feature|bugfix|hotfix|chore)\\/[a-z0-9][a-z0-9-]*$"
      }
    }
  ]
}
