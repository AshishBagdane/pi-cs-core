{
  "name": "@aethrekh/pi-cs-core",
  "version": "0.1.0",
  "description": "Core shared library for pi-cs packages — semester detection, workspace management, integrity guard, progress tracking, and configuration",
  "keywords": [
    "academic",
    "computer-science",
    "teaching-assistant",
    "pi",
    "pi-package",
    "core"
  ],
  "author": "Ashish Bagdane <ashishbagdane1@gmail.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "config"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "prepublishOnly": "pnpm run build",
    "release": "release-it"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "release-it": "^20.2.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AshishBagdane/pi-cs-core.git"
  },
  "bugs": {
    "url": "https://github.com/AshishBagdane/pi-cs-core/issues"
  },
  "homepage": "https://github.com/AshishBagdane/pi-cs-core#readme"
}
