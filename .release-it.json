{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "push": true,
    "requireCleanWorkingDir": true
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          { "type": "feat", "section": "### Added" },
          { "type": "fix", "section": "### Fixed" },
          { "type": "docs", "section": "### Changed" },
          { "type": "refactor", "section": "### Changed" },
          { "type": "perf", "section": "### Changed" },
          { "type": "test", "section": "### Changed", "hidden": true },
          { "type": "ci", "section": "### Changed", "hidden": true },
          { "type": "chore", "section": "### Changed", "hidden": true }
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog\n\nAll notable changes to pi-cs-core will be documented in this file.\n\nThe format is based on [Keep a Changelog](https://keepachangelog.com/en/1.0.0/),\nand this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).\n\n---"
    }
  }
}
