# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/

# ── TypeScript incremental build info ─────────────────────────────────────────
*.tsbuildinfo

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/
junit.xml

# ── Pack / release artifacts ──────────────────────────────────────────────────
*.tgz
*.tar.gz
dist/pack/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Allow committed example files
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS artifacts ──────────────────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# Linux
*~

# ── Editor / IDE ──────────────────────────────────────────────────────────────
# VS Code — keep extensions.json and recommended settings, ignore personal overrides
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
# JetBrains
.idea/
*.iml
*.iws
*.ipr
# Vim / Neovim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
tmp/

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/
